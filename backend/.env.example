# Backend Environment Configuration Example

# Required for Weather & Geo Alerts
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Database Configuration
MONGO_URI=mongodb://localhost:27017

# Razorpay Integration (For Marketplace)
RAZORPAY_KEY=your_razorpay_key_here
RAZORPAY_SECRET=your_razorpay_secret_here

# Vapi Outbound AI Calls integration
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
VAPI_USER_PHONE=your_user_phone_number_here

# Gemini API Key for specific tasks
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Cache URI (Optional but Recommended for Performance)
REDIS_URL=redis://localhost:6379
